# backups created by `sync.py install` (these live in ~/.claude, not here, but ignore just in case)
*.bak

# project-level CLAUDE.md is local-only (repo-navigation context, not part of the shipped
# bundle) — see docs/DECISIONS.md 2026-07-05. Not the bundled claude/CLAUDE.md.
/CLAUDE.md

# Python bytecode cache (e.g. from running or compiling sync.py)
__pycache__/
# Live workflow-task sandbox (drafts + marker). Ephemeral per task, never shipped;
# kept out of %TEMP% so a temp sweep cannot destroy an in-progress step.
/.wf-sandbox/
